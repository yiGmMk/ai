        <item>
        <title>NVIDIA 发布 UniRelight：基于扩散模型的通用视频重照明技术</title>
        <link>https://ai.programnotes.cn/p/nvidia-%E5%8F%91%E5%B8%83-unirelight%E5%9F%BA%E4%BA%8E%E6%89%A9%E6%95%A3%E6%A8%A1%E5%9E%8B%E7%9A%84%E9%80%9A%E7%94%A8%E8%A7%86%E9%A2%91%E9%87%8D%E7%85%A7%E6%98%8E%E6%8A%80%E6%9C%AF/</link>
